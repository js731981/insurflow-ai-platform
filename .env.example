APP_NAME="Insurance AI Decision Platform"
LLM_PROVIDER=ollama
# Preferred config key (MODEL_NAME is deprecated but still supported)
LLM_MODEL=phi3:mini
# Per-attempt wall-clock cap for LLM calls (router timeout + provider HTTP timeout).
# Increase if your local model is slow or prompts are long.
LLM_TIMEOUT=60
# Hard cap for FraudAgent work within a claim request (fast-fail).
FRAUD_AGENT_TIMEOUT=8
RAG_TOP_K=1
# Router retries: "2" means retry twice after the first attempt (total attempts = 3).
LLM_RETRIES=2
MAX_LLM_RETRIES=0
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=claims

# Multimodal image triage (POST /claims and /claim: JSON image_base64 or multipart field `image`)
ENABLE_IMAGE_ANALYSIS=true
IMAGE_MODEL_TYPE=heuristic
IMAGE_FUSION_WEIGHT=0.2

# Optional: path to fine-tuned MobileNetV2 weights for 3-class damage classifier.
# If unset or invalid, the system will safely fall back to heuristic image analysis.
IMAGE_CNN_MODEL_PATH=./model.pth
